# URL pública do site (produção). Usada no sitemap.xml.
# Exemplo: https://www.luzagoalimentos.com.br
SITE_URL=

# URL do Web App do Google Apps Script (formulários → Google Sheets).
# Implantar google-apps-script.gs como App da Web e colar a URL /exec aqui.
SHEETS_WEB_APP_URL=

# Opcional: mesma chave em CONFIG.WEBHOOK_SECRET no Apps Script.
SHEETS_WEBHOOK_SECRET=
